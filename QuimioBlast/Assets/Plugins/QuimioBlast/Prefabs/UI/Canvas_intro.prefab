  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp-firstpass::IntroManager
  painelIntro: {fileID: 429328345453720750}
  textoIntroducao: {fileID: 8016535745423928408}
  textoPiscante: {fileID: 8474850649230114609}
  tempoAtePiscar: 10
  tempoDeDigitacaoTotal: 8
  historia: "Em um laborat\xF3rio de pesquisa um esp\xE9cime escapou da conten\xE7\xE3o
    e saiu de controle, todo o local foi evacuado com os sobreviventes \xE0s pressas
    e o protocolo de quarentena foi instaurado no per\xEDmetro. Agora o local se
    encontra tomado por experimentos raivosos e descontrolados.\r\nVoc\xEA, um rob\xF4
    chamado RAL (Rob\xF4 Alquimista de Limpeza), foi criado pelos que fugiram a tempo
    com a miss\xE3o de recuperar o controle do laborat\xF3rio. Armado com sua alquimia
    destrutiva, sua miss\xE3o \xE9 erradicar os experimentos restantes e limpar o
    antigo laborat\xF3rio.\r\n"
  aoTerminarIntro:
    m_PersistentCalls:
      m_Calls: []
